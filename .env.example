# Copiez ce fichier en `.env` et adaptez les valeurs avant de lancer
# `docker compose up -d`. Toutes les valeurs entre <...> doivent être changées.

# ----- Base de données PostgreSQL -----
POSTGRES_USER=kanby
POSTGRES_PASSWORD=kanby
POSTGRES_DB=kanby

# ----- Application -----
# Port exposé sur la machine hôte.
APP_PORT=3000
# URL publique de l'application (sert à configurer le flag Secure des cookies).
# Mettez https://... si vous utilisez HTTPS devant.
APP_URL=http://localhost:3000

# ----- Sécurité -----
# Secret utilisé pour signer les sessions JWT. METTEZ UNE CHAÎNE ALÉATOIRE LONGUE.
# Exemple pour la générer : openssl rand -hex 32
JWT_SECRET=changez-moi-avec-une-chaine-aleatoire-de-64-caracteres
# Durée de vie des sessions en secondes (30 jours par défaut).
JWT_EXPIRES_IN=2592000

# ----- Compte administrateur par défaut -----
# Au premier démarrage, un compte admin est créé automatiquement avec ces
# identifiants. IL EST OBLIGATOIRE DE CHANGER LE MOT DE PASSE À LA PREMIÈRE
# CONNEXION (l'application forcera ce changement).
AUTO_ADMIN_ON_BOOT=true
DEFAULT_ADMIN_EMAIL=admin@kanby.local
DEFAULT_ADMIN_PASSWORD=changeme123
DEFAULT_ADMIN_NAME=Administrateur

# (Optionnel) Si vrai et qu'aucun utilisateur n'existe, le premier inscrit
# devient automatiquement admin. Utile en dev sans admin par défaut.
AUTO_ADMIN_FIRST=false