// Kanby — Prisma schema
// Self-hosted Kanban task manager.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Global role of a user.
enum GlobalRole {
  USER
  ADMIN
}

/// Whether a board is private to its owner or shared with a team.
enum BoardType {
  PERSONAL
  TEAM
}

/// Role of a member within a team board.
enum BoardRole {
  OWNER
  MEMBER
}

/// Semantic kind of a column. DONE drives the confetti celebration.
enum ColumnKind {
  TODO
  DOING
  DONE
}

model User {
  id               String     @id @default(cuid())
  email            String     @unique
  displayName      String
  passwordHash     String
  avatarUrl        String?
  globalRole       GlobalRole @default(USER)
  /// If true, the user is forced to change their password on next visit.
  mustChangePwd    Boolean    @default(false)
  active           Boolean    @default(true)
  createdAt        DateTime   @default(now())

  ownedBoards      Board[]        @relation("BoardOwner")
  memberships      BoardMember[]
  assignedCards    Card[]         @relation("CardAssignee")
  comments         Comment[]
  apiTokens        ApiToken[]

  @@index([globalRole])
}

model ApiToken {
  id         String    @id @default(cuid())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  label      String
  /// SHA-256 hash of the raw token. Never store the raw token.
  tokenHash  String    @unique
  /// First 8 chars of the raw token, shown in the UI for identification.
  prefix     String
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([tokenHash])
  @@index([userId])
}

model Board {
  id        String    @id @default(cuid())
  name      String
  type      BoardType
  owner     User      @relation("BoardOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId   String
  columns   Column[]
  labels    Label[]
  members   BoardMember[]
  cards     Card[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([ownerId])
  @@index([type])
}

model BoardMember {
  id       String    @id @default(cuid())
  board    Board     @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId  String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  role     BoardRole @default(MEMBER)
  joinedAt DateTime  @default(now())

  @@unique([boardId, userId])
  @@index([userId])
}

model Column {
  id      String     @id @default(cuid())
  board   Board      @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId String
  name    String
  kind    ColumnKind @default(TODO)
  /// Sort index within the board.
  order   Int
  /// Optional color accent shown next to the column name.
  color   String?
  cards   Card[]

  @@index([boardId, order])
}

model Card {
  id          String     @id @default(cuid())
  column      Column     @relation(fields: [columnId], references: [id], onDelete: Cascade)
  columnId    String
  board       Board      @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId     String
  title       String
  description String?
  /// Optional due date — used by the widget summary.
  dueDate     DateTime?
  /// Sort index within the column.
  order       Int
  assignee    User?      @relation("CardAssignee", fields: [assigneeId], references: [id])
  assigneeId  String?
  labels      CardLabel[]
  checklist   ChecklistItem[]
  comments    Comment[]
  /// Set when the card is moved into a DONE column.
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([boardId])
  @@index([columnId, order])
  @@index([dueDate])
  @@index([assigneeId])
}

model Label {
  id      String      @id @default(cuid())
  board   Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId String
  name    String
  color   String
  cards   CardLabel[]

  @@index([boardId])
}

model CardLabel {
  card    Card  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  cardId  String
  label   Label @relation(fields: [labelId], references: [id], onDelete: Cascade)
  labelId String

  @@id([cardId, labelId])
}

model ChecklistItem {
  id    String  @id @default(cuid())
  card  Card    @relation(fields: [cardId], references: [id], onDelete: Cascade)
  cardId String
  text  String
  done  Boolean @default(false)
  order Int

  @@index([cardId, order])
}

model Comment {
  id        String   @id @default(cuid())
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  cardId    String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String
  text      String
  createdAt DateTime @default(now())

  @@index([cardId, createdAt])
}